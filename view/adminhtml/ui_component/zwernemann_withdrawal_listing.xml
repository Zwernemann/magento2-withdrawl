<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">zwernemann_withdrawal_listing.zwernemann_withdrawal_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>zwernemann_withdrawal_columns</spinner>
        <deps>
            <dep>zwernemann_withdrawal_listing.zwernemann_withdrawal_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="zwernemann_withdrawal_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Zwernemann_Withdrawal::withdrawals</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="zwernemann_withdrawal_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="confirm">
                <settings>
                    <url path="withdrawal/index/massupdatestatus">
                        <param name="status">confirmed</param>
                    </url>
                    <type>confirm</type>
                    <label translate="true">Confirm</label>
                    <confirm>
                        <title translate="true">Confirm Withdrawals</title>
                        <message translate="true">Are you sure you want to confirm the selected withdrawal requests?</message>
                    </confirm>
                </settings>
            </action>
            <action name="reject">
                <settings>
                    <url path="withdrawal/index/massupdatestatus">
                        <param name="status">rejected</param>
                    </url>
                    <type>reject</type>
                    <label translate="true">Reject</label>
                    <confirm>
                        <title translate="true">Reject Withdrawals</title>
                        <message translate="true">Are you sure you want to reject the selected withdrawal requests?</message>
                    </confirm>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="zwernemann_withdrawal_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="entity_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="order_increment_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Order #</label>
            </settings>
        </column>
        <column name="customer_name" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Name</label>
            </settings>
        </column>
        <column name="customer_email" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>
        <column name="status" sortOrder="50" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <dataType>select</dataType>
                <options>
                    <option name="pending" xsi:type="array">
                        <item name="value" xsi:type="string">pending</item>
                        <item name="label" xsi:type="string" translate="true">Pending</item>
                    </option>
                    <option name="confirmed" xsi:type="array">
                        <item name="value" xsi:type="string">confirmed</item>
                        <item name="label" xsi:type="string" translate="true">Confirmed</item>
                    </option>
                    <option name="rejected" xsi:type="array">
                        <item name="value" xsi:type="string">rejected</item>
                        <item name="label" xsi:type="string" translate="true">Rejected</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="withdrawal_type" sortOrder="55" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Withdrawal Type</label>
                <dataType>select</dataType>
                <options>
                    <option name="full" xsi:type="array">
                        <item name="value" xsi:type="string">full</item>
                        <item name="label" xsi:type="string" translate="true">Full Withdrawal</item>
                    </option>
                    <option name="partial" xsi:type="array">
                        <item name="value" xsi:type="string">partial</item>
                        <item name="label" xsi:type="string" translate="true">Partial Withdrawal</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="withdrawn_item_count" sortOrder="56">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Withdrawn Items</label>
            </settings>
        </column>
        <column name="order_created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="60">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Order Placed At</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="70">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Withdrawal Requested At</label>
            </settings>
        </column>
        <column name="comment" sortOrder="80">
            <settings>
                <filter>text</filter>
                <label translate="true">Comment</label>
                <visible>false</visible>
            </settings>
        </column>
        <actionsColumn name="actions" class="Zwernemann\Withdrawal\Ui\Component\Listing\Column\Actions" sortOrder="90">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
