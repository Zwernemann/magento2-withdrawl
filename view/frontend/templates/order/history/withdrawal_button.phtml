<?php
/** @var \Zwernemann\Withdrawal\Block\Order\WithdrawalButton $block */
$order = $block->getOrder();
?>
<?php if ($order && $block->isEnabled()): ?>
    <td class="col withdrawal" data-th="<?= $block->escapeHtmlAttr(__('Withdrawal')) ?>">
        <?php $withdrawal = $block->getWithdrawal((int) $order->getEntityId()); ?>
        <?php if ($withdrawal !== null): ?>
            <a href="<?= $block->escapeUrl($block->getViewUrl((int) $order->getEntityId())) ?>"
               class="withdrawal-status withdrawal-status-<?= $block->escapeHtmlAttr($withdrawal->getData('status')) ?>"
               title="<?= $block->escapeHtmlAttr(__('Withdrawal')) ?>">
                <?= $block->escapeHtml($withdrawal->getStatusLabel()) ?>
            </a>
        <?php elseif ($block->isWithdrawalAllowed($order)): ?>
            <a href="<?= $block->escapeUrl($block->getViewUrl((int) $order->getEntityId())) ?>"
               class="action primary"
               title="<?= $block->escapeHtmlAttr(__('Withdraw Order')) ?>">
                <span><?= $block->escapeHtml(__('Withdraw')) ?></span>
            </a>
        <?php else: ?>
            <span class="withdrawal-status expired">
                <?= $block->escapeHtml(__('Withdrawal period expired')) ?>
            </span>
        <?php endif; ?>
    </td>
<?php endif; ?>
