<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Search Order for Withdrawal</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Zwernemann\Withdrawal\Block\Guest\Search"
                   name="withdrawal.guest.search"
                   template="Zwernemann_Withdrawal::guest/search.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
