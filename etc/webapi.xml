<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/zwernemann/withdrawals" method="GET">
        <service class="Zwernemann\Withdrawal\Api\WithdrawalRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zwernemann_Withdrawal::withdrawals"/>
        </resources>
    </route>
    <route method="POST" url="/V1/withdrawal/confirmation">
        <service class="Zwernemann\Withdrawal\Api\WithdrawalConfirmationInterface" method="sendConfirmation"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route method="POST" url="/V1/withdrawal/can-withdraw">
        <service class="Zwernemann\Withdrawal\Api\WithdrawalConfirmationInterface" method="canWithdraw"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
