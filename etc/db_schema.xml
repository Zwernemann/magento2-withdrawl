<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="zwernemann_withdrawal" resource="default" engine="innodb" comment="Withdrawal Requests">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false" comment="Order ID"/>
        <column xsi:type="varchar" name="order_increment_id" length="32" nullable="false"
                comment="Order Increment ID"/>
        <column xsi:type="varchar" name="customer_email" length="255" nullable="false"
                comment="Customer Email"/>
        <column xsi:type="varchar" name="customer_name" length="255" nullable="true"
                comment="Customer Name"/>
        <column xsi:type="varchar" name="status" length="32" nullable="false" default="pending"
                comment="Withdrawal Status"/>
        <column xsi:type="text" name="comment" nullable="true" comment="Comment"/>
        <column xsi:type="text" name="withdrawn_items" nullable="true" comment="JSON serialized withdrawn item IDs"/>
        <column xsi:type="varchar" name="withdrawal_type" length="32" nullable="false" default="full" comment="full or partial"/>
        <column xsi:type="int" name="withdrawn_item_count" unsigned="true" nullable="false" default="0" comment="Number of withdrawn items"/>
        <column xsi:type="timestamp" name="order_created_at" nullable="true"
                comment="Order Created At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="ZWERNEMANN_WITHDRAWAL_ORDER_ID_UNIQUE">
            <column name="order_id"/>
        </constraint>
        <index referenceId="ZWERNEMANN_WITHDRAWAL_ORDER_INCREMENT_ID" indexType="btree">
            <column name="order_increment_id"/>
        </index>
    </table>
    <table name="zwernemann_withdrawal_guest_token" resource="default" engine="innodb" comment="Guest Withdrawal Access Tokens">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false" comment="Order ID"/>
        <column xsi:type="varchar" name="email" length="255" nullable="false" comment="Customer Email"/>
        <column xsi:type="varchar" name="token" length="64" nullable="false" comment="Access Token"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="ZWERNEMANN_WITHDRAWAL_GUEST_TOKEN_TOKEN_UNIQUE">
            <column name="token"/>
        </constraint>
        <index referenceId="ZWERNEMANN_WITHDRAWAL_GUEST_TOKEN_ORDER_ID" indexType="btree">
            <column name="order_id"/>
        </index>
        <index referenceId="ZWERNEMANN_WITHDRAWAL_GUEST_TOKEN_EMAIL" indexType="btree">
            <column name="email"/>
        </index>
    </table>
</schema>
